TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
STARTUP_MESSAGE_ENABLED=true
STANDBY_CHECK_ENABLED=true
POLL_INTERVAL_SECONDS=30
HTTP_TIMEOUT_SECONDS=5
DB_TIMEOUT_SECONDS=5
CONSECUTIVE_FAILURES=2
REDIS_MEMORY_USAGE_THRESHOLD_PERCENT=80
# If Redis maxmemory and Docker container memory limit are both unlimited, keep it informational by default.
REDIS_MEMORY_FAIL_ON_UNBOUNDED=false

WEB_HEALTH_URL=https://korion.io.kr/health
API_HEALTH_URL=https://api.korion.io.kr/health

PRIMARY_DB_HOST=172.31.36.110
PRIMARY_DB_PORT=15432
PRIMARY_DB_NAME=coin_system_cloud
PRIMARY_DB_USER=foxya
PRIMARY_DB_PASSWORD=

STANDBY_DB_HOST=
STANDBY_DB_PORT=15432
STANDBY_DB_NAME=coin_system_cloud
STANDBY_DB_USER=foxya
STANDBY_DB_PASSWORD=

DB_CRITICAL_PROBE_SQL=SELECT 1 FROM public.coin_prices LIMIT 1
DB_CATALOG_PROBE_SQL=SELECT 1 FROM pg_catalog.pg_statistic LIMIT 1
STANDBY_REPLAY_LAG_SECONDS_THRESHOLD=120

# Optional Foxya runtime checks.
FOXYA_RUNTIME_CHECK_ENABLED=false
# socket: use mounted /var/run/docker.sock on the Foxya host.
# ssh: connect to FOXYA_SSH_HOST and run sudo docker commands.
FOXYA_DOCKER_CHECK_MODE=socket
FOXYA_DOCKER_SOCKET_PATH=/var/run/docker.sock
FOXYA_SSH_HOST=52.200.97.155
FOXYA_SSH_USER=ubuntu
FOXYA_SSH_PORT=22
FOXYA_SSH_KEY_PATH=/run/secrets/korion.pem
FOXYA_SSH_TIMEOUT_SECONDS=15
FOXYA_DOCKER_CONTAINERS=foxya-api,foxya-api-2,foxya-db-proxy,foxya-postgres,foxya-redis
FOXYA_LOG_CONTAINERS=foxya-api,foxya-api-2,foxya-db-proxy
FOXYA_LOG_LOOKBACK_MINUTES=10
FOXYA_CRITICAL_LOG_PATTERNS=ClosedConnectionException,Failed to read any response from the server,Connection is closed,Connection refused: db-proxy,Connection refused: db-proxy/.*5432,connect ECONNREFUSED,Connection terminated unexpectedly,UnknownHostException,Failed to resolve 'redis',Failed to connect to Redis,Failed to start MainVerticle,backend-unresolved,runtime-conflict,status:restarting,postgres.*NOSRV,could not resolve address.*postgres,server postgres/primary is DOWN
FOXYA_IGNORED_LOG_PATTERNS=Unauthorized,프로필 이미지를 찾을 수 없습니다
FOXYA_REDIS_MEMORY_CHECK_ENABLED=false
FOXYA_REDIS_CONTAINERS=foxya-redis

# Optional offline_pay critical log checks.
OFFLINE_PAY_RUNTIME_CHECK_ENABLED=false
OFFLINE_PAY_SSH_HOST=98.91.96.182
OFFLINE_PAY_SSH_USER=ubuntu
OFFLINE_PAY_SSH_PORT=22
OFFLINE_PAY_SSH_KEY_SOURCE=/home/ubuntu/.ssh/korion.pem
OFFLINE_PAY_SSH_KEY_PATH=/run/secrets/korion.pem
OFFLINE_PAY_SSH_TIMEOUT_SECONDS=15
OFFLINE_PAY_LOG_CONTAINERS=korion_offline-app-api-1,korion_offline-app-worker-1
OFFLINE_PAY_LOG_LOOKBACK_MINUTES=10
OFFLINE_PAY_CRITICAL_LOG_PATTERNS=Offline Pay Settlement Dead Letter,offline_pay\\.collateral\\.dead_letter,COLLATERAL_LOCK_FAIL,INSUFFICIENT_BALANCE,Failed to request settlement,HISTORY_SYNC_FAIL,RECEIVER_HISTORY_SYNC_REQUESTED,value too long for type character varying,circuit opened,coin_manage collateral request failed,foxya.*status 5[0-9][0-9],coin_manage.*status 5[0-9][0-9]
OFFLINE_PAY_IGNORED_LOG_PATTERNS=
OFFLINE_PAY_REDIS_MEMORY_CHECK_ENABLED=false
OFFLINE_PAY_REDIS_CONTAINERS=korion_offline-redis-1

# Optional coin_manage runtime, log, and Redis memory checks.
COIN_MANAGE_RUNTIME_CHECK_ENABLED=false
COIN_MANAGE_SSH_HOST=54.83.183.123
COIN_MANAGE_SSH_USER=ubuntu
COIN_MANAGE_SSH_PORT=22
COIN_MANAGE_SSH_KEY_PATH=/run/secrets/korion.pem
COIN_MANAGE_SSH_TIMEOUT_SECONDS=15
COIN_MANAGE_DOCKER_CONTAINERS=korion-app-api-1,korion-app-ops-1,korion-app-signer-1,korion-app-withdraw-worker-1,korion-postgres,korion-redis,ledger-signer
COIN_MANAGE_LOG_CONTAINERS=korion-app-api-1,korion-app-ops-1,korion-app-signer-1,korion-app-withdraw-worker-1,ledger-signer
COIN_MANAGE_LOG_LOOKBACK_MINUTES=10
COIN_MANAGE_REDIS_MEMORY_CHECK_ENABLED=false
COIN_MANAGE_REDIS_CONTAINERS=korion-redis

# Optional coin_csms runtime, log, and Redis memory checks.
COIN_CSMS_RUNTIME_CHECK_ENABLED=false
COIN_CSMS_SSH_HOST=52.200.97.155
COIN_CSMS_SSH_USER=ubuntu
COIN_CSMS_SSH_PORT=22
COIN_CSMS_SSH_KEY_PATH=/run/secrets/korion.pem
COIN_CSMS_SSH_TIMEOUT_SECONDS=15
COIN_CSMS_DOCKER_CONTAINERS=csms-api
COIN_CSMS_LOG_CONTAINERS=csms-api
COIN_CSMS_LOG_LOOKBACK_MINUTES=10
COIN_CSMS_REDIS_MEMORY_CHECK_ENABLED=false
COIN_CSMS_REDIS_CONTAINERS=
